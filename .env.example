# ============================================================================
# NOT: Aşağıdaki host adları Docker Compose servis adlarıdır (postgres, redis,
# minio). Uygulamayı Docker DIŞINDA (host'ta) çalıştırıyorsanız bu adları
# 'localhost' ile değiştirin.
# ============================================================================

# Veritabanı
DATABASE_URL=postgresql+psycopg2://postgres:postgres@postgres:5432/kitap_db
ASYNC_DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/kitap_db
# Testler için ayrı veritabanı (Spec Bölüm 15)
TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/kitap_test

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# JWT
SECRET_KEY=change-me-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Üretim LLM (Anthropic) — GLOBAL VARSAYILAN; project_settings.llm_config bunları EZER (Bölüm 8.4)
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=8000
ANTHROPIC_TEMPERATURE=0.5

# Embedding (semantik hafıza) — Bölüm 10
SEMANTIC_MEMORY_ENABLED=true
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
OPENAI_API_KEY=sk-REPLACE_ME
VOYAGE_API_KEY=

# MinIO / S3
S3_ENDPOINT=http://minio:9000
S3_BUCKET=kitap-yazilimi
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
PRESIGNED_URL_EXPIRE_HOURS=24

# App
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
SENTRY_DSN=
